# ============================================================
# LLM Provider Configuration
# ============================================================
# 選擇 LLM Provider: 'openai', 'openrouter', 或 'ollama'
# - openai: 使用官方 OpenAI API（默認）
# - openrouter: 使用 OpenRouter（支援多種模型，成本較低）
# - ollama: 使用本地或遠端 Ollama 服務（完全自主控制）
LLM_PROVIDER=openai

# OpenAI API Key（LLM_PROVIDER=openai 時需要）
OPENAI_API_KEY=sk-proj-your-api-key-here

# OpenRouter API Key（LLM_PROVIDER=openrouter 時需要）
# 註冊網址: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-your-api-key-here

# Ollama API URL（LLM_PROVIDER=ollama 時需要）
# 本地部署: http://localhost:11434
# 遠端服務: http://your-ollama-server:11434
OLLAMA_API_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# AI Model Configuration
# ============================================================
# 以下模型名稱會根據 LLM_PROVIDER 自動適配：
# - OpenAI: gpt-3.5-turbo, gpt-4o-mini, gpt-4o
# - OpenRouter: anthropic/claude-3.5-sonnet, meta-llama/llama-3-70b, etc.
# - Ollama: llama2, mistral, mixtral, etc.

# Intent Classifier Configuration
INTENT_CLASSIFIER_MODEL=gpt-3.5-turbo    # 意圖分類模型 (gpt-3.5-turbo/gpt-4o-mini/gpt-4)
INTENT_CLASSIFIER_TEMPERATURE=0.1         # 意圖分類溫度 (0.0-1.0)
INTENT_CLASSIFIER_MAX_TOKENS=500          # 意圖分類最大 tokens

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aichatbot_admin
DB_USER=aichatbot
DB_PASSWORD=aichatbot_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache Configuration (Redis TTL settings)
CACHE_ENABLED=true                # 是否啟用緩存 (true/false)
CACHE_TTL_QUESTION=3600           # 問題緩存 TTL（秒）- 預設 1 小時
CACHE_TTL_VECTOR=7200             # 向量緩存 TTL（秒）- 預設 2 小時
CACHE_TTL_RAG_RESULT=1800         # RAG 結果緩存 TTL（秒）- 預設 30 分鐘

# API URLs (for local development)
EMBEDDING_API_URL=http://localhost:5001/api/v1/embeddings
KNOWLEDGE_ADMIN_API_URL=http://localhost:8000/api

# AI Model Configuration
# 知識生成專用模型（成本較低，用於生成知識候選答案）
KNOWLEDGE_GEN_MODEL=gpt-3.5-turbo

# 規格書轉換專用模型（高品質，用於處理 Word/PDF 規格書轉換為知識庫）
DOCUMENT_CONVERTER_MODEL=gpt-4o

# AWS S3 (影片儲存)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=aichatbot-knowledge-videos
CLOUDFRONT_DOMAIN=                     # (可選) CloudFront CDN 網域

# Priority Boost Configuration
PRIORITY_BOOST=0.15                    # 優先級加成值 (啟用時的固定加成，建議 0.10-0.20)
PRIORITY_QUALITY_THRESHOLD=0.70         # 優先級品質門檻 (只對高品質答案加分，預設 0.70)

# Quality Evaluation Configuration
QUALITY_EVALUATION_ENABLED=true     # 是否啟用質量評估 (true/false)
QUALITY_EVALUATION_THRESHOLD=6      # 質量評估門檻 (1-10，建議 6-8，8=非常嚴格)

# ============================================================
# Retriever Similarity Thresholds
# ============================================================
# 各閾值對應 retriever pipeline 的不同分數欄位，詳見
# docs/architecture/retriever-pipeline.md
#
# 分數欄位語意：
#   vector_similarity   純向量 cosine 分數（0.0–1.0，不含 boost/rerank）
#   similarity          final 組合分數（retriever 輸出，含 rerank/boost）
#
# PERFECT_MATCH_THRESHOLD：比對 vector_similarity（純向量分數，language-agnostic 語義匹配）
#   → 重構後閾值語意改變（原比對含 boost 的 similarity），需依校準結果調整
#   → 預估映射：0.90（舊）→ 0.82（新），最終值以回測校準為準
PERFECT_MATCH_THRESHOLD=0.90

# SOP_SIMILARITY_THRESHOLD：比對 final similarity（application 端過濾 SOP 候選）
SOP_SIMILARITY_THRESHOLD=0.75

# KB_SIMILARITY_THRESHOLD：比對 final similarity（application 端過濾知識庫候選）
KB_SIMILARITY_THRESHOLD=0.65

# HIGH_QUALITY_THRESHOLD：比對 final similarity（高品質判定，用於答案合成觸發）
HIGH_QUALITY_THRESHOLD=0.80

# SYNTHESIS_THRESHOLD：比對 final similarity（_should_synthesize 合成觸發判定）
SYNTHESIS_THRESHOLD=0.80

# ============================================================
# Query Rewriting（查詢改寫）
# ============================================================
# 用 LLM 將租戶口語改寫為物業管理用語，提升向量匹配率
# 成本：~$0.001/次，延遲：~300-500ms
ENABLE_QUERY_REWRITE=true
QUERY_REWRITE_MODEL=gpt-3.5-turbo
QUERY_REWRITE_TEMPERATURE=0.3
QUERY_REWRITE_MAX_TOKENS=100

# ============================================================
# Semantic Reranker Performance Tuning
# ============================================================
# 詳見 .kiro/issues/reranker-returning-zero.md
# bge-reranker-base CPU 推論對大批次較慢（>30 筆 ~27s），
# 這兩個參數協同避免 client timeout 導致 reranker 失效。

# 送進 reranker 的候選數上限（依 vector_similarity 取 top N）
# 20 筆約 1 批次 6-8s，能在 timeout 內完成
RERANKER_INPUT_LIMIT=20

# 送進 reranker 的 vector_similarity 下限
# vector 低於此值的候選幾乎不可能 rerank 後進 top_k，跳過以節省推論時間
# 注意：keyword_fallback 項目不受此下限影響（它們 vector_similarity=0 是設計預設值）
RERANKER_MIN_VECTOR_SIMILARITY=0.3

# Reranker HTTP client timeout（秒）。預設 60s 留餘裕。
RERANKER_HTTP_TIMEOUT=60
