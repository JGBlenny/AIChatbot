  "api_convention": {
    "description": "以下所有 API 規格均遵循 JGB client-guide.md 的慣例",
    "base_url": "https://www.jgbsmart.com",
    "auth": "X-API-Key header（同現有 estates API）",
    "path_prefix": "/api/external/v1/",
    "response_format": {
      "success_example": {
        "success": true,
        "mapping": {"status": {"2": "應到帳", "16": "已到帳"}},
        "data": [],
        "pagination": {"current_page": 1, "per_page": 50, "total": 0, "total_pages": 0, "has_more": false}
      },
      "error_example": {
        "success": false,
        "error": {"code": 401, "message": "API Key 無效或未提供"}
      }
    },
    "pagination": "page + per_page（預設 50，最大 200）",
    "rate_limit": "60 次/分鐘，建議間隔 0.5 秒",
    "common_error_codes": {
      "401": "API Key 無效或未提供",
      "403": "無權存取此資料",
      "404": "資源不存在",
      "429": "請求過於頻繁，請稍後再試"
    }
  },

  "api_specs": [
    {
      "id": "API-1",
      "name": "帳單查詢",
      "priority": "must-have",
      "path": "GET /api/external/v1/bills",
      "covers_scenarios": ["A1 租客看不到帳單", "A3 帳單未到帳原因", "A4 發票未開立原因", "A8 續約後帳單未產生"],
      "frequency_justification": "帳務是最大類別（303/679 筆客戶回饋），帳單狀態查詢是 AI 客服最核心的能力",
      "request": {
        "method": "GET",
        "headers": {"X-API-Key": "{API_KEY}"},
        "params": [
          {"name": "role_id", "type": "integer", "required": true, "description": "管理者角色 ID"},
          {"name": "user_id", "type": "integer", "required": false, "description": "租客用戶 ID（篩選特定租客）"},
          {"name": "contract_id", "type": "integer", "required": false, "description": "合約 ID（篩選特定合約的帳單）"},
          {"name": "status", "type": "integer", "required": false, "description": "帳單狀態碼篩選"},
          {"name": "month", "type": "string", "required": false, "description": "篩選月份（YYYY-MM）"},
          {"name": "page", "type": "integer", "required": false, "description": "頁碼（預設 1）"},
          {"name": "per_page", "type": "integer", "required": false, "description": "每頁筆數（預設 50，最大 200）"},
          {"name": "sort_by", "type": "string", "required": false, "description": "排序欄位（date_expire, created_at, total）"},
          {"name": "sort_direction", "type": "string", "required": false, "description": "排序方向（asc, desc）"}
        ]
      },
      "response": {
        "success_example": {
          "success": true,
          "mapping": {
            "status": {
              "comment": "請提供完整的帳單狀態碼對照表",
              "2": "應到帳",
              "16": "已到帳",
              "64": "逾期",
              "?": "草稿/待對帳/已封存 等（需 JGB 補充）"
            },
            "invoice_status": {
              "0": "未開立",
              "1": "已開立",
              "2": "已作廢"
            }
          },
          "data": [
            {
              "id": 12345,
              "contract_id": 678,
              "estate_id": 456,
              "estate_name": "信義區套房A",
              "status": 2,
              "title": "2026年4月租金",
              "currency": "TWD",
              "total": 25000.00,
              "date_expire": "2026-04-05",
              "invoice_status": 0,
              "invoice_number": null,
              "pay_at": null,
              "complete_at": null,
              "created_at": "2026-03-25 10:30:00",
              "updated_at": "2026-04-01 00:00:00"
            }
          ],
          "pagination": {
            "current_page": 1,
            "per_page": 50,
            "total": 1,
            "total_pages": 1,
            "has_more": false
          }
        }
      },
      "questions_for_jgb": [
        "帳單狀態碼完整清單？目前 mock 假設 2=應到帳、16=已到帳、64=逾期，實際是否有草稿、待對帳、已封存等？是 bitmask 還是 enum？",
        "帳單是否有 virtual_account（虛擬帳號）欄位可回傳？AI 可直接告訴租客帳號",
        "用 role_id 查詢時，回傳該管理者旗下所有租客的帳單嗎？加 user_id 篩選特定租客？"
      ]
    },
