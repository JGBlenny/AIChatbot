      "auth": "X-API-Key header",
      "path_prefix": "/api/external/v1/",
      "endpoints": ["GET /estates", "GET /estates/{id}"],
      "response_format": "{ success, mapping, data, pagination }",
      "error_format": "{ success: false, error: { code, message } }",
      "pagination": "page + per_page（max 200）",
      "rate_limit": "60 次/分鐘"
    },
    "our_api_endpoints_table": {
