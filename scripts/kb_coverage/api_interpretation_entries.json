{
  "description": "Task 12.2 API 解讀知識 — 表單 + 知識條目（全部 form_fill → call_api）",

  "form_schemas": [
    {
      "form_id": "jgb_bill_query",
      "form_name": "帳單狀態查詢",
      "description": "查詢特定帳單的狀態與繳費資訊",
      "fields": [
        {
          "field_name": "bill_keyword",
          "field_label": "帳單編號或標題",
          "field_type": "text",
          "prompt": "請提供帳單編號或帳單標題（例如：12345 或 2026年4月租金）",
          "required": true,
          "validation_type": "free_text"
        }
      ],
      "default_intro": "好的，我來幫您查詢帳單狀態。",
      "on_complete_action": "call_api",
      "api_config": {
        "endpoint": "jgb_bills",
        "params": {
          "role_id": "{session.role_id}",
          "user_id": "{session.user_id}"
        }
      },
      "skip_review": true
    },
    {
      "form_id": "jgb_invoice_query",
